# ── Google Gemini (FREE — 1500 requests/day) ──────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Instagram credentials ──────────────────────────────────────────────────────
INSTA_USERNAME=your_instagram_username_no_at
INSTA_PASSWORD=your_instagram_password
INSTA_HANDLE=@your_instagram_handle

# ── Auto-managed: do NOT set on first run ─────────────────────────────────────
# After the first successful run, copy NEW_SESSION_B64 from the logs
# and add it as a GitHub Secret named INSTA_SESSION.
INSTA_SESSION=

# ── Dev flags ─────────────────────────────────────────────────────────────────
# Set to true to generate slides without posting
DRY_RUN=false

# Force a specific topic instead of auto-picking (leave blank for auto)
TOPIC_OVERRIDE=
